  class_contexts_path: ./imagedistribution_attributes/eurosat-imagedistribution-contexts-GPT3.json
  class_descriptor_path: ./eurosat-text-corpus-GPT3-coop.json
  class_embeddings_path: ./imagedistribution_attributes/eurosat/
  general_class: False
INPUT:
  COLORJITTER_B: 0.4
  COLORJITTER_C: 0.4
  COLORJITTER_H: 0.1
  COLORJITTER_S: 0.4
  CROP_PADDING: 4
  CUTOUT_LEN: 16
  CUTOUT_N: 1
  GB_K: 21
  GB_P: 0.5
  GN_MEAN: 0.0
  GN_STD: 0.15
  INTERPOLATION: bicubic
